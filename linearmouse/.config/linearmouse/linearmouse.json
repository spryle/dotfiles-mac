{
  "$schema": "https://schema.linearmouse.app/0.11.2",
  "schemes": [
    {
      "if": {
        "device": { "category": "mouse" }
      },
      "scrolling": {
        "reverse": { "vertical": true },
        "distance": { "vertical": 14, "horizontal": 14 },
        "smoothed": { "enabled": false }
      }
    }
  ]
}
