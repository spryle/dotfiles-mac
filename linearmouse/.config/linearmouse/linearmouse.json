{
  "$schema": "https://schema.linearmouse.app/0.11.2",
  "schemes": [
    {
      "if": {
        "device": { "category": "mouse" }
      },
      "scrolling": {
        "reverse": { "vertical": true },
        "distance": { "vertical": 10, "horizontal": 10 },
        "smoothed": { "enabled": true, "preset": "easeInOut" }
      }
    }
  ]
}
