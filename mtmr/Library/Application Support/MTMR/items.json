// MTMR Touch Bar — Omarchy-style live AeroSpace workspaces.
// Left: escape + workspaces 1-10 (●N focused, N occupied, · empty); tap to jump.
// Right: brightness, volume, battery, clock. Generated — see install.sh.
[
  {
    "type": "escape",
    "width": 56,
    "align": "left"
  },
  {
    "type": "shellScriptTitledButton",
    "align": "left",
    "width": 30,
    "bordered": true,
    "source": {
      "inline": "export PATH=/opt/homebrew/bin:$PATH; f=$(aerospace list-workspaces --focused); if [ \"$f\" = \"1\" ]; then echo \"●1\"; elif aerospace list-workspaces --monitor all --empty no | grep -qx 1; then echo \"1\"; else echo \"·\"; fi"
    },
    "refreshInterval": 1,
    "action": "shellScript",
    "executablePath": "/opt/homebrew/bin/aerospace",
    "shellArguments": [
      "workspace",
      "1"
    ]
  },
